{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "cron": [
      {
        "command": "cd /app && node retryPendingPayouts.js --prod",
        "schedule": "0 * * * *",
        "description": "Retry pending vendor payouts every hour"
      }
    ]
  }
}
